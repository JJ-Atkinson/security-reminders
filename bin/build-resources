#!/usr/bin/env bash
set -euo pipefail

# Ensure npm dependencies are installed
npm install

# Create public directories
mkdir -p resources/public/css resources/public/js

# Copy zprint config so it's available on the classpath in prod
cp .zprintrc resources/config/zprintrc.edn

# Bundle JavaScript (minified via terser plugin in rollup.config.js)
NODE_ENV=production npx rollup -c rollup.config.js

# Copy dev-ws.js separately (not bundled, only used in dev)
cp resources/js/dev-ws.js resources/public/js/

# Build Tailwind CSS (minified, purged)
NODE_ENV=production npx tailwindcss -i ./resources/css/input.css -o ./resources/public/css/output.css --minify

echo "Resources built successfully in resources/public/"
